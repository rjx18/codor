{
  "name": "wireroom",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:all": "pnpm -r build && pnpm -r test && pnpm --filter @wireroom/web e2e",
    "lint": "pnpm -r --if-present lint",
    "audit:license": "node scripts/license-audit.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sodium-native",
      "udx-native"
    ]
  }
}
